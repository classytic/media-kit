{
  "name": "@classytic/media-kit",
  "version": "2.1.0",
  "description": "Production-grade media management powered by mongokit - storage drivers, status lifecycle, focal points, soft deletes, asset transforms, and smart pagination",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./providers/s3": {
      "types": "./dist/providers/s3.d.mts",
      "import": "./dist/providers/s3.mjs"
    },
    "./providers/gcs": {
      "types": "./dist/providers/gcs.d.mts",
      "import": "./dist/providers/gcs.mjs"
    },
    "./providers/local": {
      "types": "./dist/providers/local.d.mts",
      "import": "./dist/providers/local.mjs"
    },
    "./providers/router": {
      "types": "./dist/providers/router.d.mts",
      "import": "./dist/providers/router.mjs"
    },
    "./transforms": {
      "types": "./dist/transforms.d.mts",
      "import": "./dist/transforms.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cleanup": "npx tsx tests/cleanup-s3-test-files.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck",
    "publish:dry": "npm publish --dry-run --access public",
    "publish:npm": "npm publish --access public",
    "release": "npm run build && npm run test && npm run typecheck && npm publish --access public",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release"
  },
  "keywords": [
    "media",
    "mongoose",
    "mongokit",
    "s3",
    "gcs",
    "image-upload",
    "file-management",
    "mongodb",
    "storage",
    "multitenancy",
    "pagination",
    "cursor-pagination",
    "repository-pattern",
    "focal-point",
    "soft-delete",
    "asset-transform",
    "image-processing"
  ],
  "author": "Classytic <classytic.dev@gmail.com> (https://github.com/classytic)",
  "contributors": [
    "Sadman Chowdhury (https://github.com/siam923)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/classytic/media-kit.git"
  },
  "homepage": "https://github.com/classytic/media-kit#readme",
  "bugs": {
    "url": "https://github.com/classytic/media-kit/issues"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.1014.0",
    "@aws-sdk/s3-request-presigner": ">=3.1014.0",
    "@classytic/mongokit": ">=3.3.2",
    "@google-cloud/storage": ">=7.19.0",
    "mime-types": ">=2.1.35",
    "mongoose": ">=9.3.1",
    "sharp": ">=0.34.5"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@google-cloud/storage": {
      "optional": true
    },
    "mime-types": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/core": ">=0.18.2",
    "@aws-sdk/client-s3": ">=3.1014.0",
    "@aws-sdk/s3-request-presigner": ">=3.1014.0",
    "@classytic/mongokit": ">=3.3.2",
    "@google-cloud/storage": ">=7.19.0",
    "@types/mime-types": ">=2.1.4",
    "@types/node": ">=22.0.0",
    "dotenv": ">=17.3.1",
    "mongoose": ">=9.3.1",
    "publint": ">=0.3.18",
    "sharp": ">=0.34.5",
    "tsdown": ">=0.21.4",
    "typescript": ">=5.0.0",
    "vitest": ">=4.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}