{
  "name": "@classytic/media-kit",
  "version": "3.2.0",
  "description": "Engine-factory media management for Mongoose and Arc — arc-compatible events, dynamic multi-tenancy, pluggable storage drivers, smart pagination, image processing",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./providers/s3": {
      "types": "./dist/providers/s3.d.mts",
      "import": "./dist/providers/s3.mjs"
    },
    "./providers/gcs": {
      "types": "./dist/providers/gcs.d.mts",
      "import": "./dist/providers/gcs.mjs"
    },
    "./providers/local": {
      "types": "./dist/providers/local.d.mts",
      "import": "./dist/providers/local.mjs"
    },
    "./providers/imgbb": {
      "types": "./dist/providers/imgbb.d.mts",
      "import": "./dist/providers/imgbb.mjs"
    },
    "./providers/imagekit": {
      "types": "./dist/providers/imagekit.d.mts",
      "import": "./dist/providers/imagekit.mjs"
    },
    "./providers/cloudinary": {
      "types": "./dist/providers/cloudinary.d.mts",
      "import": "./dist/providers/cloudinary.mjs"
    },
    "./providers/router": {
      "types": "./dist/providers/router.d.mts",
      "import": "./dist/providers/router.mjs"
    },
    "./transforms": {
      "types": "./dist/transforms.d.mts",
      "import": "./dist/transforms.mjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.mts",
      "import": "./dist/schemas.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --project unit --project integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:e2e": "vitest run --project e2e",
    "test:all": "vitest run",
    "test:smoke": "npm run build && node tests/smoke/dist-exports.mjs",
    "test:bench": "vitest bench --run",
    "test:watch": "vitest --project unit --project integration",
    "test:cleanup": "npx tsx tests/cleanup-s3-test-files.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run typecheck",
    "publish:dry": "npm publish --dry-run --access public",
    "publish:npm": "npm publish --access public",
    "release": "npm run build && npm run test && npm run typecheck && npm publish --access public",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release",
    "push": "classytic-push"
  },
  "keywords": [
    "media",
    "mongoose",
    "mongokit",
    "arc",
    "engine",
    "s3",
    "gcs",
    "image-upload",
    "file-management",
    "mongodb",
    "storage",
    "multitenancy",
    "pagination",
    "cursor-pagination",
    "repository-pattern",
    "focal-point",
    "soft-delete",
    "asset-transform",
    "image-processing",
    "event-driven"
  ],
  "author": "Classytic <classytic.dev@gmail.com> (https://github.com/classytic)",
  "contributors": [
    "Sadman Chowdhury (https://github.com/siam923)"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/classytic/media-kit.git"
  },
  "homepage": "https://github.com/classytic/media-kit#readme",
  "bugs": {
    "url": "https://github.com/classytic/media-kit/issues"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.1014.0",
    "@aws-sdk/s3-request-presigner": ">=3.1014.0",
    "@classytic/mongokit": ">=3.13.0",
    "@classytic/primitives": ">=0.4.0",
    "@classytic/repo-core": ">=0.4.0",
    "@google-cloud/storage": ">=7.19.0",
    "mime-types": ">=3.0.2",
    "mongoose": ">=9.4.1",
    "sharp": ">=0.34.5",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@google-cloud/storage": {
      "optional": true
    },
    "mime-types": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/core": ">=0.18.2",
    "@aws-sdk/client-s3": ">=3.1014.0",
    "@aws-sdk/s3-request-presigner": ">=3.1014.0",
    "@classytic/dev-tools": "^0.2.0",
    "@classytic/mongokit": "^3.13.0",
    "@classytic/primitives": "^0.4.0",
    "@classytic/repo-core": "^0.4.0",
    "@google-cloud/storage": ">=7.19.0",
    "@types/mime-types": ">=3.0.1",
    "@types/node": ">=22.0.0",
    "@vitest/coverage-v8": ">=4.1.0",
    "dotenv": ">=17.3.1",
    "mongodb-memory-server": ">=10.0.0",
    "mongoose": ">=9.4.1",
    "publint": ">=0.3.18",
    "sharp": ">=0.34.5",
    "tsdown": ">=0.21.8",
    "tsx": ">=4.20.0",
    "typescript": ">=5.0.0",
    "vitest": ">=4.1.0",
    "zod": ">=4.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "@tootallnate/once": ">=3.0.1",
    "uuid": ">=14.0.0",
    "gaxios": ">=7.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
